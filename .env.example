# Шаблон для .env — скопируйте в .env и впишите реальные значения.
# .env в git не попадает (см. .gitignore) — этот файл безопасен для приватного репозитория как образец.

STUDENT_BOT_TOKEN=your_student_bot_token_here
PARENT_BOT_TOKEN=your_parent_bot_token_here

# T10-10A: узкий server-to-server API вместо прямого Data API/publishable key.
STUDENT_BOT_API_URL=https://<ref>.functions.supabase.co/student-bot-api
STUDENT_BOT_API_SECRET=your_student_bot_api_secret_here
